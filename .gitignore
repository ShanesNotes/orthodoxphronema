# Staging is ephemeral — never commit raw parse output to canon
staging/raw/
staging/quarantine/

# OS / editor artifacts
.DS_Store
*.swp
*.swo
__pycache__/
*.pyc
.env

# Build / tooling artifacts
.coverage
*.egg-info/
orthodoxphronema.egg-info/
nodesource_setup.sh

# Claude Code — track harness, ignore session data
.claude/projects/
.claude/todos/
.claude/credentials*
.claude/statsig/
.claude/tmp/

# Source texts (large, not for git)
src.texts/

# Pipeline — procedural scripts kept local, not published
# GitHub shows project output artifacts, not the tooling to get there
pipeline/

# Experimental — agent harness prototypes (local development)
experimental/

# Research — external AI outputs (non-governing, informational only)
research/

# Skills — local project toolkits (bridged to .claude/skills/)
skills/

# One-off build scripts (local only)
*.js
!metadata/**/*.js
pm_roadmap.js
x_article_docx.js

# Virtual environment
.venv/

# Local dev scripts
.claude/status.sh

# DuckDB graph (regeneratable from Layer 2 backlink shards)
metadata/graph/*.duckdb
