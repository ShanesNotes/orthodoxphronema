{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Anchor Backlink Shard (v2 — Enriched)",
  "description": "Enriched domain-specific backlinks for a single canon anchor. Superset of v1 with verse text, pericope context, topic threads, and depth metadata.",
  "type": "object",
  "required": ["anchor_id", "canon_uri", "text_tradition", "generated_at", "generator_version", "schema_version", "verse_text", "pericope", "topic_threads", "depth_available", "links"],
  "properties": {
    "anchor_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+\\.\\d+:\\d+$",
      "description": "Canon anchor (e.g. GEN.1:1)"
    },
    "canon_uri": {
      "type": "string",
      "description": "Relative path to canon file + anchor fragment (e.g. canon/OT/GEN.md#GEN.1:1)"
    },
    "text_tradition": {
      "type": "string",
      "enum": ["LXX"],
      "description": "Textual tradition of the canon anchor"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this shard was generated"
    },
    "generator_version": {
      "type": "string",
      "description": "Version tag of the backlink builder that produced this shard"
    },
    "schema_version": {
      "type": "string",
      "const": "v2",
      "description": "Schema version identifier"
    },
    "verse_text": {
      "type": "string",
      "description": "Canon verse text extracted at enrichment time (anchor prefix stripped)"
    },
    "pericope": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "title", "range"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[A-Z0-9]+\\.P\\d{3}$",
              "description": "Synthetic pericope ID (e.g. GEN.P001)"
            },
            "title": {
              "type": "string",
              "description": "Pericope title from pericope index"
            },
            "range": {
              "type": "string",
              "description": "Anchor range (e.g. GEN.1:1-2:6)"
            },
            "liturgical_use": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Liturgical occasions where this pericope is read"
            }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ],
      "description": "Pericope context for this anchor, or null if not indexed"
    },
    "topic_threads": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Semantic topic labels for relevance filtering (initially empty)"
    },
    "depth_available": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "description": "Maximum content depth available: 1=verse, 2=+footnote/article, 3=+graph, 4=+patristic"
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/backlink_entry" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "backlink_entry": {
      "type": "object",
      "required": ["source_file", "line_number", "raw_match", "reference_type", "context"],
      "properties": {
        "source_file": {
          "type": "string",
          "description": "Relative path to the source file containing the reference"
        },
        "line_number": {
          "type": "integer",
          "minimum": 1,
          "description": "Line number in the source file where the reference occurs"
        },
        "raw_match": {
          "type": "string",
          "description": "The raw text matched (e.g. [[GEN.1:1]], [[GEN.1:1]]-3)"
        },
        "reference_type": {
          "type": "string",
          "enum": ["wikilink", "wikilink_range", "bare"],
          "description": "Type of reference found"
        },
        "context": {
          "type": "string",
          "description": "Surrounding text providing context for the reference"
        }
      },
      "additionalProperties": false
    }
  }
}
